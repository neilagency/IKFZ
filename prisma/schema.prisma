// Prisma schema for iKFZ Digital Zulassung CMS + E-commerce
// SQLite database for pages, posts, SEO, admin, and shop

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ═══════════════════════════════════════════════
// CMS MODELS
// ═══════════════════════════════════════════════

// Admin Users
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Pages (from WordPress)
model Page {
  id            String    @id @default(cuid())
  wpId          Int?      @unique
  slug          String    @unique
  title         String
  content       String
  excerpt       String?
  template      String?
  status        String    @default("published")
  menuOrder     Int       @default(0)
  pageType      String    @default("generic")
  featuredImage String?
  parentSlug    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  publishedAt   DateTime?
  seo           SEO?
}

// Blog Posts (flat model — category/tags as strings)
model BlogPost {
  id              String    @id @default(cuid())
  wpPostId        Int?      @unique
  slug            String    @unique
  title           String
  content         String
  excerpt         String    @default("")
  featuredImage   String    @default("")
  featuredImageId String    @default("")
  status          String    @default("draft")
  author          String    @default("Admin")
  metaTitle       String    @default("")
  metaDescription String    @default("")
  focusKeyword    String    @default("")
  canonical       String    @default("")
  robots          String    @default("index, follow")
  ogTitle         String    @default("")
  ogDescription   String    @default("")
  ogImage         String    @default("")
  category        String    @default("")
  tags            String    @default("")
  views           Int       @default(0)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([status, scheduledAt])
}

// Categories
model Category {
  id          String   @id @default(cuid())
  wpCatId     Int?     @unique
  name        String   @unique
  slug        String   @unique
  description String   @default("")
  count       Int      @default(0)
  parent      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// Tags
model Tag {
  id          String   @id @default(cuid())
  wpTagId     Int?     @unique
  name        String   @unique
  slug        String   @unique
  description String   @default("")
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// SEO Metadata
model SEO {
  id              String  @id @default(cuid())
  pageId          String? @unique
  productId       String? @unique
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  ogType          String? @default("website")
  twitterCard     String? @default("summary_large_image")
  twitterTitle    String?
  twitterDesc     String?
  twitterImage    String?
  robots          String? @default("follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large")
  schemaJson      String?
  focusKeyword    String?
  page            Page?   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  product         Product?
}

// Redirects
model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique
  toPath     String
  statusCode Int      @default(301)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// Media (uploads)
model Media {
  id            String   @id @default(cuid())
  wpMediaId     Int?     @unique
  fileName      String   @default("")
  originalName  String   @default("")
  title         String   @default("")
  altText       String   @default("")
  sourceUrl     String   @default("")
  localPath     String   @default("")
  thumbnailUrl  String   @default("")
  mediumUrl     String   @default("")
  largeUrl      String   @default("")
  webpUrl       String   @default("")
  avifUrl       String   @default("")
  mimeType      String   @default("")
  width         Int      @default(0)
  height        Int      @default(0)
  fileSize      Int      @default(0)
  folder        String   @default("")
  usedIn        String   @default("[]")
  useCount      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Site Settings
model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ═══════════════════════════════════════════════
// E-COMMERCE MODELS
// ═══════════════════════════════════════════════

// Shop Products
model Product {
  id               String          @id @default(cuid())
  wcId             Int?            @unique
  name             String
  slug             String          @unique
  type             String          @default("simple")
  status           String          @default("publish")
  description      String?
  shortDescription String?
  sku              String?
  price            Float           @default(0)
  regularPrice     Float           @default(0)
  salePrice        Float?
  currency         String          @default("EUR")
  stockStatus      String          @default("instock")
  stockQuantity    Int?
  weight           String?
  featured         Boolean         @default(false)
  catalogVisibility String         @default("visible")
  taxStatus        String          @default("taxable")
  taxClass         String?
  permalink        String?
  // Service-specific fields
  serviceType      String?         // anmeldung, abmeldung
  formType         String?         // anmeldung, abmeldung
  options          String?         // JSON: [{key, label, price}]
  isActive         Boolean         @default(true)
  metaDescription  String?
  ogImage          String?
  heroTitle        String?
  heroSubtitle     String?
  faq              String?         // JSON: [{question, answer}]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  images           ProductImage[]
  productCategories ProductProductCategory[]
  orderItems       OrderItem[]
  seo              SEO?            @relation(fields: [seoId], references: [id])
  seoId            String?         @unique
}

// Product Images
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  wcId      Int?
  src       String
  name      String?
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Product Categories (WooCommerce)
model ProductCategory {
  id          String                    @id @default(cuid())
  wcId        Int?                      @unique
  name        String
  slug        String                    @unique
  description String?
  count       Int                       @default(0)
  products    ProductProductCategory[]
}

model ProductProductCategory {
  productId  String
  categoryId String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

// Customers (extracted from orders)
model Customer {
  id        String   @id @default(cuid())
  wcId      Int?     @unique
  email     String   @unique
  firstName String?
  lastName  String?
  company   String?
  phone     String?
  // Billing Address
  billingAddress1  String?
  billingAddress2  String?
  billingCity      String?
  billingState     String?
  billingPostcode  String?
  billingCountry   String?
  // Shipping Address
  shippingAddress1 String?
  shippingAddress2 String?
  shippingCity     String?
  shippingState    String?
  shippingPostcode String?
  shippingCountry  String?
  // Auth fields (customer login)
  password         String?
  totalOrders      Int       @default(0)
  totalSpent       Float     @default(0)
  lastLoginAt      DateTime?
  // Email subscription
  emailSubscribed  Boolean   @default(true)
  unsubscribeToken String    @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([createdAt])
  @@index([emailSubscribed])
}

// Orders
model Order {
  id                String      @id @default(cuid())
  wcId              Int?        @unique
  orderNumber       String?
  status            String      @default("pending")
  currency          String      @default("EUR")
  total             Float       @default(0)
  subtotal          Float       @default(0)
  totalTax          Float       @default(0)
  shippingTotal     Float       @default(0)
  discountTotal     Float       @default(0)
  paymentMethod     String?
  paymentMethodTitle String?
  transactionId     String?
  customerNote      String?
  // Service-specific fields
  serviceData       String?         // JSON: form data from service forms
  productName       String?
  paymentFee        Float           @default(0)
  // Billing Info (denormalized for historical accuracy)
  billingFirstName  String?
  billingLastName   String?
  billingCompany    String?
  billingEmail      String?
  billingPhone      String?
  billingAddress1   String?
  billingAddress2   String?
  billingCity       String?
  billingState      String?
  billingPostcode   String?
  billingCountry    String?
  // Shipping Info
  shippingFirstName String?
  shippingLastName  String?
  shippingAddress1  String?
  shippingAddress2  String?
  shippingCity      String?
  shippingState     String?
  shippingPostcode  String?
  shippingCountry   String?
  // Relations
  customerId        String?
  customer          Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payment           Payment?
  invoice           Invoice?
  notes             OrderNote[]
  documents         OrderDocument[]
  messages          OrderMessage[]
  // Coupon / Discount
  couponCode        String      @default("")
  discountAmount    Float       @default(0)
  completionEmailSent Boolean   @default(false)
  // Dates
  datePaid          DateTime?
  dateCompleted     DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// Order Line Items
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String?
  wcProductId Int?
  name        String
  quantity    Int     @default(1)
  price       Float   @default(0)
  total       Float   @default(0)
  totalTax    Float   @default(0)
  sku         String?
  // Meta data (JSON string for flexibility)
  metaData    String?
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// Payments
model Payment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  method          String
  methodTitle     String?
  transactionId   String?
  status          String   @default("pending")
  amount          Float    @default(0)
  currency        String   @default("EUR")
  paidAt          DateTime?
  gatewayResponse String?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Invoices
model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  invoiceNumber String   @unique
  status        String   @default("issued")
  amount        Float    @default(0)
  currency      String   @default("EUR")
  issuedAt      DateTime @default(now())
  dueAt         DateTime?
  paidAt        DateTime?
  billingName   String?
  billingEmail  String?
  billingAddress String?
  items         String?
  notes         String?
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

// ═══════════════════════════════════════════════
// ORDER EXTENSIONS
// ═══════════════════════════════════════════════

// Order Notes (admin/system notes)
model OrderNote {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  note      String
  author    String   @default("system")
  createdAt DateTime @default(now())

  @@index([orderId])
}

// Order Messages (admin ↔ customer communication)
model OrderMessage {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  message     String
  attachments String   @default("[]")
  sentBy      String   @default("admin")
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

// Order Documents (PDFs uploaded by admin)
model OrderDocument {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileSize  Int      @default(0)
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ═══════════════════════════════════════════════
// EMAIL CAMPAIGNS
// ═══════════════════════════════════════════════

model EmailCampaign {
  id              String    @id @default(cuid())
  name            String
  subject         String    @default("")
  heading         String    @default("")
  content         String    @default("")
  imageUrl        String    @default("")
  ctaText         String    @default("")
  ctaUrl          String    @default("")

  // Targeting
  targetMode      String    @default("all")
  targetEmails    String    @default("")
  targetSegment   String    @default("")

  // Scheduling
  scheduledAt     DateTime?

  // Tracking
  openCount       Int       @default(0)
  clickCount      Int       @default(0)

  // Template
  templateId      String    @default("")

  status          String    @default("draft")
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  errorLog        String    @default("")

  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([scheduledAt])
}

// ═══════════════════════════════════════════════
// COUPONS / DISCOUNT CODES
// ═══════════════════════════════════════════════

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String    @default("")
  discountType    String    @default("fixed")
  discountValue   Float     @default(0)
  minOrderValue   Float     @default(0)
  maxUsageTotal   Int       @default(0)
  maxUsagePerUser Int       @default(1)
  usageCount      Int       @default(0)
  productSlugs    String    @default("")

  isActive        Boolean   @default(true)
  showBanner      Boolean   @default(false)
  bannerText      String    @default("")

  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usages          CouponUsage[]

  @@index([code])
  @@index([isActive])
  @@index([endDate])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  email     String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([couponId, email])
  @@index([email])
  @@index([couponId])
}
